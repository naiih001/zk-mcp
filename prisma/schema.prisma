generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String   @db.Text
  body      String   @default("") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tags      NoteTag[]  @relation("NoteToNoteTags")
  links     Link[]     @relation("SourceNoteLinks")
  backlinks Link[]     @relation("TargetNoteLinks")
  todoLinks TodoNote[] @relation("NoteTodoLinks")
  checklistItems ChecklistItem[] @relation("NoteChecklistItems")

  @@index([updatedAt(sort: Desc)], map: "idx_notes_updated_at")
  @@map("notes")
}

model Tag {
  id    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String    @unique @db.Text
  notes NoteTag[] @relation("TagToNoteTags")

  @@map("tags")
}

model NoteTag {
  noteId String @map("note_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  note Note @relation("NoteToNoteTags", fields: [noteId], references: [id], onDelete: Cascade)
  tag  Tag  @relation("TagToNoteTags", fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId], map: "idx_note_tags_tag")
  @@map("note_tags")
}

model Todo {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String    @db.Text
  description String    @default("") @db.Text
  status      String    @default("pending") @db.Text
  priority    Int       @default(0)
  dueDate     DateTime? @map("due_date") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  notes TodoNote[] @relation("TodoToNotes")

  @@index([status], map: "idx_todos_status")
  @@index([updatedAt(sort: Desc)], map: "idx_todos_updated_at")
  @@map("todos")
}

model TodoNote {
  todoId    String   @map("todo_id") @db.Uuid
  noteId    String   @map("note_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  todo Todo @relation("TodoToNotes", fields: [todoId], references: [id], onDelete: Cascade)
  note Note @relation("NoteTodoLinks", fields: [noteId], references: [id], onDelete: Cascade)

  @@id([todoId, noteId])
  @@index([noteId], map: "idx_todo_notes_note")
  @@map("todo_notes")
}

model Link {
  sourceNoteId String   @map("source_note_id") @db.Uuid
  targetNoteId String   @map("target_note_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  source Note @relation("SourceNoteLinks", fields: [sourceNoteId], references: [id], onDelete: Cascade)
  target Note @relation("TargetNoteLinks", fields: [targetNoteId], references: [id], onDelete: Cascade)

  @@id([sourceNoteId, targetNoteId])
  @@index([targetNoteId], map: "idx_links_target")
  @@map("links")
}

model ChecklistItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  noteId    String   @map("note_id") @db.Uuid
  text      String   @db.Text
  checked   Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  note Note @relation("NoteChecklistItems", fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, position], map: "idx_checklist_items_note_position")
  @@index([checked], map: "idx_checklist_items_checked")
  @@map("checklist_items")
}
