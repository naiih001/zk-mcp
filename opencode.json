{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "zk": {
      "type": "remote",
      "url": "https://zk-mcp-1.onrender.com/mcp",
      "enabled": true
    },
    "render": {
      "type": "remote",
      "url": "https://mcp.render.com/mcp",
